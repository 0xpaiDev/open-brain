# Open Brain — Caddy reverse proxy
# Caddy auto-provisions TLS certificates via Let's Encrypt.
# Replace {$DOMAIN} by setting the DOMAIN environment variable, or hardcode the domain.
# Example: openbrain.yourdomain.com

{$DOMAIN} {
    # Enable gzip compression
    encode gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server fingerprinting
        -Server
    }

    # API routes → FastAPI backend
    handle /v1/* {
        reverse_proxy api:8000
    }

    # Health/readiness probes → FastAPI backend
    handle /ready {
        reverse_proxy api:8000
    }

    handle /health {
        reverse_proxy api:8000
    }

    # Everything else → Next.js frontend
    handle {
        reverse_proxy web:3000
    }

    # Access logs
    log {
        output stdout
        format json
        level INFO
    }
}
