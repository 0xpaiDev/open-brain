# Database (Supabase)
# Find this in Supabase project dashboard: Settings → Database → Connection pooler
# Use direct connection (port 5432), NOT the pooler (port 6543)
# Format: postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SQLALCHEMY_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# API
API_KEY=your-secret-api-key-here
# Database SSL mode (set to "disable" for local development, "require" for production)
DB_SSL_MODE=require

# LLM
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Embeddings
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3

# Application
LOG_LEVEL=info

# Worker
WORKER_POLL_INTERVAL=5
WORKER_LOCK_TTL_SECONDS=300

# Embeddings dimensions (do not change after initial deployment)
EMBEDDING_DIMENSIONS=1024

# Importance scoring
IMPORTANCE_RECENCY_HALF_LIFE_DAYS=30
# Base importance ceiling for auto-captured sessions (source="claude-code")
AUTO_CAPTURE_IMPORTANCE_CEILING=0.4

# Search
SEARCH_VECTOR_WEIGHT=0.5
SEARCH_KEYWORD_WEIGHT=0.2
SEARCH_IMPORTANCE_WEIGHT=0.2
SEARCH_RECENCY_WEIGHT=0.1

# Entity resolution
ENTITY_FUZZY_MATCH_THRESHOLD=0.92

# Context builder
CONTEXT_TOKEN_BUDGET=8192

# Refinement queue
DEAD_LETTER_RETRY_LIMIT=3

# Synthesis
SYNTHESIS_MAX_MEMORIES_PER_REPORT=50
SYNTHESIS_MODEL=claude-haiku-4-5-20251001
# For production quality, override with: SYNTHESIS_MODEL=claude-opus-4-6

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MEMORY_PER_MINUTE=50
RATE_LIMIT_SEARCH_PER_MINUTE=100
RATE_LIMIT_DEAD_LETTERS_PER_MINUTE=5

# Feature flags (set to false to disable modules)
MODULE_TODO_ENABLED=true
MODULE_PULSE_ENABLED=true
MODULE_RAG_CHAT_ENABLED=true

# Discord integration (optional — leave blank to skip)
# Get token from https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=
# Comma-separated Discord user IDs allowed to use the bot (with Developer Mode on: right-click username → Copy User ID)
DISCORD_ALLOWED_USER_IDS=
# Channel ID for todo prefix listener (e.g., "- task"); 0 = disabled
DISCORD_TODO_CHANNEL_ID=0
# User ID for morning pulse DMs; 0 = disabled
DISCORD_PULSE_USER_ID=0
# Accept freetext DM replies in Morning Pulse (true = modal + DM, false = modal only)
PULSE_ACCEPT_FREETEXT=false
# Timezone for morning pulse
PULSE_TIMEZONE=UTC
# Minutes to accept pulse replies after send
PULSE_REPLY_WINDOW_MINUTES=240
# Google Calendar credentials (for optional calendar integration)
GOOGLE_CALENDAR_CREDENTIALS_PATH=
GOOGLE_CALENDAR_TOKEN_PATH=

# Integration settings
# Open Brain API URL (used by integrations running in Docker — override per service)
OPEN_BRAIN_API_URL=http://localhost:8000
# API key for integrations (Claude Code stop hook, MCP server)
OPENBRAIN_API_KEY=

# ── RAG Chat ───────────────────────────────────────────────────────────────
# Channel IDs where ?-prefixed messages trigger RAG (right-click channel → Copy ID)
DISCORD_RAG_CHANNEL_IDS=[]
# Prefix for RAG trigger (default: ?)
RAG_TRIGGER_PREFIX=?
# Default model for RAG responses (haiku for cost, sonnet for quality)
RAG_DEFAULT_MODEL=claude-haiku-4-5-20251001
# Conversation history buffer size (number of messages to keep in context)
RAG_CONVERSATION_BUFFER_SIZE=5
# Conversation TTL in hours (0 = no expiry)
RAG_CONVERSATION_TTL_HOURS=24
# Model for high-quality RAG responses (sonnet recommended)
RAG_SONNET_MODEL=claude-sonnet-4-6
# Save Q&A interactions as memory items (true = ingest, false = discard)
RAG_SAVE_QA_AS_MEMORY=false

# ── Strava Integration ────────────────────────────────────────────────────
# Get from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_FTP=190                           # Functional Threshold Power (watts) for TSS calc

# ── Training & Commitments ────────────────────────────────────────────────
MODULE_TRAINING_ENABLED=true

# ── Voice Command ─────────────────────────────────────────────────────────
# Outer timeout (seconds) for voice command LLM calls
VOICE_COMMAND_LLM_TIMEOUT_SECONDS=1.5

# Dashboard CORS origins (comma-separated)
DASHBOARD_ORIGINS=

# Production domain (used by Caddy for TLS — run with: docker compose --profile caddy up)
# DOMAIN=openbrain.yourdomain.com
